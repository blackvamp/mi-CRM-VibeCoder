# Convex — se generan al ejecutar `npx convex dev` (login interactivo) o al
# vincular el proyecto la primera vez. No commitear valores reales (usar .env.local).
NEXT_PUBLIC_CONVEX_URL=

# Deploy key de Convex para producción (Railway), solo si el build despliega
# las funciones de Convex automáticamente. https://docs.convex.dev/production/hosting
# CONVEX_DEPLOY_KEY=
